// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db?connection_limit=1&socket_timeout=5000"
}

model SKU {
  id           String           @id @default(uuid())
  code         String           @unique
  name         String
  description  String?
  units        SerializedUnit[]
  inboundItems InboundItem[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model Location {
  id          String   @id @default(uuid())
  code        String   @unique
  type        String   // WAREHOUSE, ZONE, ASRS, BIN
  parentId    String?
  parent      Location? @relation("LocationHierarchy", fields: [parentId], references: [id])
  children    Location[] @relation("LocationHierarchy")
  path        String   // Materialized path, e.g., "WH-01/ZONE-A/ASRS-01/BIN-102"
  units       SerializedUnit[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([path])
}

model SerializedUnit {
  id                String           @id @default(uuid())
  serialNumber      String           @unique
  skuId             String
  sku               SKU              @relation(fields: [skuId], references: [id])
  locationId        String?
  location          Location?        @relation(fields: [locationId], references: [id])
  inboundShipmentId String?
  inboundShipment   InboundShipment? @relation(fields: [inboundShipmentId], references: [id])
  status            String           @default("INBOUND") // INBOUND, IN_STOCK, ALLOCATED, PICKED, SHIPPED, QUARANTINE
  barcode           String?          // Case/Pallet barcode
  tagId             String?          // RFID tag ID
  metadata          String?          // JSON metadata (using String for SQLite compatibility)
  auditLogs         StatusAuditLog[]
  lastSeenAt        DateTime         @default(now())
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([status])
  @@index([barcode])
  @@index([tagId])
  @@index([inboundShipmentId])
}

model InboundShipment {
  id         String        @id @default(uuid())
  externalId String        @unique // ERP Reference ID
  vendor     String
  status     String        @default("PENDING") // PENDING, ARRIVED, COMPLETED, CANCELLED
  items      InboundItem[]
  units      SerializedUnit[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([externalId])
}

model InboundItem {
  id          String          @id @default(uuid())
  shipmentId  String
  shipment    InboundShipment @relation(fields: [shipmentId], references: [id])
  skuId       String
  sku         SKU             @relation(fields: [skuId], references: [id])
  expectedQty Int
  receivedQty Int             @default(0)

  @@index([shipmentId])
  @@index([skuId])
}

model StatusAuditLog {
  id          String         @id @default(uuid())
  unitId      String
  unit        SerializedUnit @relation(fields: [unitId], references: [id])
  fromStatus  String
  toStatus    String
  changedBy   String?        // User ID or System Service
  timestamp   DateTime       @default(now())

  @@index([unitId])
}
